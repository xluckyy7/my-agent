DASHSCOPE_API_KEY=sk-your-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEFAULT_MODEL=qwen-plus

# Logging (optional). Defaults to INFO.
# MY_AGENT_LOG_LEVEL=DEBUG    # one of DEBUG/INFO/WARNING/ERROR/CRITICAL
# MY_AGENT_DEBUG=1            # shortcut: force DEBUG (also dumps raw LLM JSON)

# Iter 5: context compaction (optional, sensible defaults baked in)
# CONTEXT_BUDGET=8000        # token budget; compaction triggers at 80%
# KEEP_RECENT_TURNS=4        # most recent user turns survive compaction verbatim

# Iter 6: web search (optional). Sign up free at https://tavily.com — 1000 queries/month.
# Without this key, the agent has web_fetch (URL → text) but no web_search.
# TAVILY_API_KEY=tvly-...

# Iter 11: langfuse observability plugin (optional).
# Enable by also putting hooks pointing at my_agent.plugins.langfuse_plugin
# into ~/.my-agent/hooks.json (see docs/notes/iter-11-retro.md).
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# Self-hosted? Set host to your instance. Both names accepted; LANGFUSE_HOST
# takes priority (matches the langfuse SDK's canonical env var name).
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_BASE_URL=https://your-self-hosted.example.com

# Optional, for later comparison:
# ANTHROPIC_API_KEY=sk-ant-...